<div class="ProductMeta">
  {%- if section.settings.show_vendor and product.vendor != blank -%}
    <h2 class="ProductMeta__Vendor Heading u-h6">
      {%- assign vendor_handle = product.vendor | handle -%}
      {%- assign collection_for_vendor = collections[vendor_handle] -%}

      {%- unless collection_for_vendor.empty? -%}
        <a href="{{ collection_for_vendor.url }}">{{ product.vendor }}</a>
      {%- else -%}
        {{- product.vendor -}}
      {%- endunless -%}
    </h2>
  {%- endif -%}

  <h1 class="ProductMeta__Title Heading u-h2">
    {% assign title_words = product.title | split: ' ' %}
    {% if title_words.size >= 2 %}
      <span class="ProductMeta__Title_fr"> {{ title_words[0] }} </span>
      <span class="product_meta_sub_title">
        {{- title_words[1] }}
        {{ title_words[2] }}
        {{ title_words[3] }}
        {{ title_words[4] }}
        {{ title_words[5] }}
        {{ title_words[6] -}}
      </span>
    {% else %}
      <span class="ProductMeta__Title_ls"> {{ product.title }}</span>
    {% endif %}
  </h1>

  {% if product.metafields.custom.benefit_text != blank %}
    <h3 class="product-benefit-text maison_test">{{- product.metafields.custom.benefit_text -}}</h3>
  {% endif %}

  <a href="#looxReviews">
    <div
      class="loox-rating"
      data-id="{{ product.id }}"
      data-rating="{{ product.metafields.loox.avg_rating }}"
      data-raters="{{ product.metafields.loox.num_reviews }}"
      style="margin-top:15px"
    ></div>
  </a>
  <div class="qty_selector_discount_title"><span>BUNDLE CONTENT</span></div>

  <div class="bundle_prodcut_description">
    
                    {% assign variantnum = 0 %}
                    {% for variant in product.variants %}
                      <div class="bundle_function_box">
                        <div class="bundle_product_name_col">
                          <div class="bundle_product_box">
                            <span class="check_svg">
                              <svg
                                width="10"
                                height="7"
                                viewBox="0 0 10 7"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                              >
                                <path
                                  d="M9.79138 1.17155L9.30473 1.63704L4.16313 6.52474L3.69763 6.96908L3.23214 6.52474L0.820028 4.23958L0.333374 3.77409L1.26436 2.80078L1.75102 3.26628L3.69763 5.08594L8.37374 0.642578L8.86039 0.177083L9.79138 1.17155Z"
                                  fill="#00FE67"></path>
                              </svg>
                            </span>
                            
                            {% if variantnum == 0 %}
                              <span class="bundle_quantity">3x</span>
                              {% assign variantnum = 1 %}
                            {% elsif variantnum == 1 %}
                              <span class="bundle_quantity">3x</span>
                              {% assign variantnum = 2 %}
                            {% else %}
                              <span class="bundle_quantity">1x</span>
                            {% endif %}
                      
                            {{ variant.title }}
                          </div>
                        </div>
                      </div>
                    {% endfor %}
  </div>

  {% comment %}
    <div class="bundle_pick_balls_wrapper">
      <div class="bundle_pick_top_col">
        <h4>{{ section.settings.pick_balls_heading }}</h4>
      </div>
      <div class="bundle_pick_balls_col">
        <div class="bundle_pick_balls_box">
          <div class="bundle_pick_ball_box_in" data-price="{{ section.settings.first_product.price }}">
            <div class="bundle_pick_image">
              <img src="{{ section.settings.first_product.featured_image | img_url:'master' }}">
            </div>
            <span>Football</span>
          </div>
        </div>
        <div class="bundle_pick_balls_box">
          <div class="bundle_pick_ball_box_in" data-price="{{ section.settings.second_product.price }}">
            <div class="bundle_pick_image">
              <img src="{{ section.settings.second_product.featured_image | img_url:'master' }}">
            </div>
            <span>Basketball</span>
          </div>
        </div>
      </div>
    </div>
  {% endcomment %}

  {% assign flag_offer = false %}
  {% assign flag_offer2 = false %}
  {% assign discount_offer_text = false %}

  {% for tag in product.tags %}
    {% if tag == 'offer1' %}
      {% assign flag_offer = true %}
    {% endif %}
    {% if tag == 'offer2' or tag == 'offer3' or tag == 'offer4' %}
      {% assign flag_offer2 = true %}
    {% endif %}
    {% if tag == 'BFCM_sale' %}
      {% assign discount_offer_text = true %}
    {% endif %}
  {% endfor %}

  {% if discount_offer_text %}
    <div class="ProductMeta__PriceList 111 Heading">
      <!--
        {% assign dis_price = product.selected_or_first_available_variant.price | times: 30 | divided_by: 100 | round %}
        {% assign get_discount_price = product.selected_or_first_available_variant.price | minus: dis_price %}
      -->

      <!--
        <span class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main" data-money-convertible>{{ get_discount_price | times: 2 | money }}</span>
      -->

      {% comment %}
        <div class="ProductMeta__PriceLis_save">
          <span>Save 50%</span>
          <span
            class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main"
            data-compare="{{ product.selected_or_first_available_variant.price | times: 2  }}"
            data-money-convertible
            ><b>was</b> {{ product.selected_or_first_available_variant.price | times: 2 | money -}}
          </span>
        </div>

        <div class="product_prices">{{ product.compare_at_price | money }}</div>
      {% endcomment %}

      <div class="percentage_price_col">
        <div class="product_prices">{{ product.compare_at_price | money }}</div>
        <div class="product_prices_sum"></div>
        <div class="product_right_price">
          {% assign savings_percentage = 100
            | times: product.compare_at_price
            | minus: product.price
            | divided_by: product.compare_at_price
          %}
          {% if savings_percentage > 0 %}
            <span class="save_bg_color"> {{ section.settings.save_percentage_text }} </span>
          {% endif %}
          <div class="product_right_total_price">Total value <span>€84,90</span></div>
        </div>
      </div>
      <!-- <span class="save_meta_price">Save $25</span> -->
    </div>
  {% else %}
    {% if flag_offer %}
      <div class="ProductMeta__PriceList  Heading">
        <span
          class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main"
          data-money-convertible
        >
          {{- product.selected_or_first_available_variant.price | minus: 1000 | money -}}
        </span>
        <div class="ProductMeta__PriceLis_save">
          <span>Save 50%</span>
          <span
            class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main"
            data-compare="{{ product.selected_or_first_available_variant.price  }}"
            data-money-convertible
            ><b>was</b> {{ product.selected_or_first_available_variant.price | money -}}
          </span>
        </div>
      </div>
    {% elsif flag_offer2 %}
      <div class="ProductMeta__PriceList  Heading">
        <span
          class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main"
          data-money-convertible
        >
          {{- product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
        </span>
        <div class="ProductMeta__PriceLis_save">
          <span>Save 50%</span>
          <span
            class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main offer_two_three"
            data-compare="{{ product.selected_or_first_available_variant.price }}"
            style="display:none;"
            data-money-convertible
            ><b>was</b> {{ product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
          </span>
        </div>
      </div>

    {% else %}
      <div class="ProductMeta__PriceList Heading">
        {%- if product.selected_or_first_available_variant.compare_at_price
            > product.selected_or_first_available_variant.price
        -%}
          <span
            class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main"
            data-money-convertible
          >
            {{- product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
          </span>
          <div class="ProductMeta__PriceLis_save">
            <span>Save 50%</span>
            <span class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5" data-money-convertible>
              {{- product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros -}}
            </span>
          </div>
        {%- else -%}
          <span class="ProductMeta__Price Price Text--subdued u-h3 changable_price_main" data-money-convertible>
            {{- product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
          </span>
        {%- endif -%}
      </div>
    {% endif %}
  {% endif %}

  {%- if show_description
    and section.settings.description_below_add_to_cart == false
    and product.description != blank
  -%}
    <div class="ProductMeta__Description Rte">
      {{ product.description }}
    </div>
  {%- endif -%}
</div>

<script>
  {% comment %}
    const footballButton = document.querySelector('.bundle_pick_ball_box_in[data-price="{{ section.settings.first_product.price }}"]');
  const basketballButton = document.querySelector('.bundle_pick_ball_box_in[data-price="{{ section.settings.second_product.price }}"]');
  const totalPriceDisplay = document.getElementById('total-price-display');

  let totalPrice = {{ section.settings.first_product.price }};

  footballButton.addEventListener('click', () => {
    if (totalPrice !== {{ section.settings.first_product.price }}) {
      totalPrice -= {{ section.settings.second_product.price }};
      totalPrice += {{ section.settings.first_product.price }};
      totalPriceDisplay.textContent = totalPrice;
    }
  });

  basketballButton.addEventListener('click', () => {
    if (totalPrice !== {{ section.settings.second_product.price }}) {
      totalPrice -= {{ section.settings.first_product.price }};
      totalPrice += {{ section.settings.second_product.price }};
      totalPriceDisplay.textContent = totalPrice;
    }
  });

  {% endcomment %}
</script>
