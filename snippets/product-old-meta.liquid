<div class="ProductMeta">
  {%- if section.settings.show_vendor and product.vendor != blank -%}
    <h2 class="ProductMeta__Vendor Heading u-h6">
      {%- assign vendor_handle = product.vendor | handle -%}
      {%- assign collection_for_vendor = collections[vendor_handle] -%}

      {%- unless collection_for_vendor.empty? -%}
        <a href="{{ collection_for_vendor.url }}">{{ product.vendor }}</a>
      {%- else -%}
        {{- product.vendor -}}
      {%- endunless -%}
    </h2>
  {%- endif -%}

  <h1 class="ProductMeta__Title Heading u-h2">
    {%- if template.name == 'product' -%}
      {{- product.title -}}
    {%- else -%}
      <a href="{{ product.url }}">{{ product.title }}</a>
    {%- endif -%}
  </h1>

  {% if product.metafields.custom.benefit_text != blank %}
    <h3 class="product-benefit-text maison_test">{{- product.metafields.custom.benefit_text -}}</h3>
  {% endif %}

  <a href="#looxReviews">
    <div
      class="loox-rating"
      data-id="{{ product.id }}"
      data-rating="{{ product.metafields.loox.avg_rating }}"
      data-raters="{{ product.metafields.loox.num_reviews }}"
      style="margin-top:15px"></div>
  </a>

  {% assign flag_offer = false %}
  {% assign flag_offer2 = false %}
  {% assign discount_offer_text = false %}

  {% for tag in product.tags %}
    {% if tag == 'offer1' %}
      {% assign flag_offer = true %}
    {% endif %}
    {% if tag == 'offer2' or tag == 'offer3' or tag == 'offer4' %}
      {% assign flag_offer2 = true %}
    {% endif %}
    {% if tag == 'BFCM_sale' %}
      {% assign discount_offer_text = true %}
    {% endif %}
  {% endfor %}

  {% if discount_offer_text %}
    <div class="ProductMeta__PriceList Heading">
      {% assign dis_price = product.selected_or_first_available_variant.price | times: 25 | divided_by: 100.0 | round %}
      {% assign get_discount_price = product.selected_or_first_available_variant.price | minus: dis_price %}

      <span class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main" data-money-convertible>{{ get_discount_price | money }}</span>
      <span
        class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main"
        data-compare="{{ product.selected_or_first_available_variant.price  }}"
        data-money-convertible>{{ product.selected_or_first_available_variant.price | money }}</span>

      <!--     <span class="save_meta_price">Save $25</span> -->
    </div>
  {% else %}
    {% if flag_offer %}
      <div class="ProductMeta__PriceList Heading">
        <span class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main" data-money-convertible>{{ product.selected_or_first_available_variant.price | minus: 1000 | money_without_trailing_zeros }}</span>
        <span
          class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main"
          data-compare="{{ product.selected_or_first_available_variant.price  }}"
          data-money-convertible>{{ product.selected_or_first_available_variant.price | money }}</span>
      </div>
    {% elsif flag_offer2 %}
      <div class="ProductMeta__PriceList Heading">
        <span class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main" data-money-convertible>{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</span>
        <span
          class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5 compare_at_price_main offer_two_three"
          data-compare="{{ product.selected_or_first_available_variant.price }}"
          style="display:none;"
          data-money-convertible>{{ product.selected_or_first_available_variant.price | money }}</span>
      </div>

    {% else %}
      <div class="ProductMeta__PriceList Heading">
        {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
          <span class="ProductMeta__Price Price Price--highlight maison_test Text--subdued u-h3 changable_price_main" data-money-convertible>{{ product.selected_or_first_available_variant.price | money_without_trailing_zeros }}</span>
          <span class="ProductMeta__Price Price Price--compareAt Text--subdued u-h5" data-money-convertible>{{ product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros }}</span>
        {%- else -%}
          <span class="ProductMeta__Price Price Text--subdued u-h3 changable_price_main" data-money-convertible>{{ product.selected_or_first_available_variant.price | money }}</span>
        {%- endif -%}
      </div>
    {% endif %}

  {% endif %}

  {%- if show_description and section.settings.description_below_add_to_cart == false and product.description != blank -%}
    <div class="ProductMeta__Description Rte">
      {{ product.description }}
    </div>
  {%- endif -%}
</div>