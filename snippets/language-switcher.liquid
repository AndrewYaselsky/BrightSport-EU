{%- comment -%}
  Native Shopify language switcher.
  Requires: Settings → Languages → add & publish at least 2 languages.
{%- endcomment -%}

{%- if localization.available_languages.size > 1 -%}
  {%- assign current_lang = localization.language.iso_code | downcase -%}

  <div class="language-switcher" id="language-switcher" data-wg-notranslate="true">
    <div class="language-switcher__inner">
      <button
        type="button"
        class="language-switcher__toggle"
        aria-expanded="false"
        aria-controls="language-switcher-menu"
        aria-label="{{ 'localization.language_label' | t | default: 'Language' }}"
      >
        <img
          class="language-switcher__flag"
          src="https://cdn.weglot.com/flags/circle/{% case current_lang %}{% when 'en' %}gb{% when 'da' %}dk{% when 'sv' %}se{% when 'nb' %}no{% when 'no' %}no{% else %}{{ current_lang }}{% endcase %}.svg"
          width="24"
          height="24"
          alt=""
          loading="lazy"
        >
        <span class="language-switcher__label">{{ localization.language.endonym_name }}</span>
        <span class="language-switcher__chevron" aria-hidden="true"></span>
      </button>

      <ul id="language-switcher-menu" class="language-switcher__menu" role="listbox" hidden>
        {%- for language in localization.available_languages -%}
          {%- assign lang_code = language.iso_code | downcase -%}
          <li class="language-switcher__item{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}" role="option">
            <a
              href="{{ language.root_url }}"
              hreflang="{{ language.iso_code }}"
              lang="{{ language.iso_code }}"
              class="language-switcher__link"
              {% if language.iso_code == localization.language.iso_code %}
                aria-current="true"
              {% endif %}
            >
              <img
                class="language-switcher__flag"
                src="https://cdn.weglot.com/flags/circle/{% case lang_code %}{% when 'en' %}gb{% when 'da' %}dk{% when 'sv' %}se{% when 'nb' %}no{% when 'no' %}no{% else %}{{ lang_code }}{% endcase %}.svg"
                width="24"
                height="24"
                alt=""
                loading="lazy"
              >
              <span>{{ language.endonym_name }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <script>
    (function () {
      function initLanguageSwitcher() {
        var root = document.getElementById('language-switcher');
        if (!root || root.dataset.initialized === 'true') return;

        var toggle = root.querySelector('.language-switcher__toggle');
        var menu = root.querySelector('.language-switcher__menu');
        if (!toggle || !menu) return;

        root.dataset.initialized = 'true';

        function openMenu() {
          root.classList.add('is-open');
          toggle.setAttribute('aria-expanded', 'true');
          menu.hidden = false;
        }

        function closeMenu() {
          root.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          menu.hidden = true;
        }

        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          if (toggle.getAttribute('aria-expanded') === 'true') closeMenu();
          else openMenu();
        });

        document.addEventListener('click', function (e) {
          if (!root.contains(e.target)) closeMenu();
        });

        toggle.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
            e.preventDefault();
            openMenu();
          }
          if (e.key === 'Escape') closeMenu();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLanguageSwitcher);
      } else {
        initLanguageSwitcher();
      }
    })();
  </script>
{%- elsif request.design_mode -%}
  <p class="language-switcher__hint">
    Add languages in Shopify Admin → Settings → Languages to show the switcher.
  </p>
{%- endif -%}
