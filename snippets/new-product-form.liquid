{%- comment -%}
  Those are the option names for which we automatically detect swatch. For the color, we use them to display a swatch, while
  for size, we use it to display a size chart (if applicable)
{%- endcomment -%}

{%- assign color_label = 'color,colour,couleur,colore,farbe,색,色,färg,farve' | split: ',' -%}
{%- assign size_label = 'size,taille,bröße,tamanho,tamaño,koko,サイズ' | split: ',' -%}

{%- assign size_chart_page = '' -%}
{%- assign product_popovers = '' -%}

{%- assign selected_variant = product.selected_or_first_available_variant -%}

{% assign flag_offer = false %}
{% assign flag_offer2 = false %}
{% assign flag_offer3 = false %}
{% assign discount_offer_text = false %}

{% for tag in product.tags %}
  {% if tag == 'BFCM_sale' or product.handle == 'bright-sport-golf-balls' %}
    {% assign discount_offer_text = true %}
  {% else %}
    {% if tag == 'offer1' %}
      {% assign flag_offer = true %}
    {% endif %}
    {% if tag == 'offer2' or tag == 'offer3' %}
      {% assign flag_offer2 = true %}
    {% endif %}
    {% if tag == 'offer4' %}
      {% assign flag_offer3 = true %}
    {% endif %}
  {% endif %}
{% endfor %}

{%- form 'product', product, class: 'ProductForm' -%}
  {% if discount_offer_text %}
    {%- liquid
      assign price1 = 0
      assign compare_at_price1 = 0
      assign save1 = 0
    
      assign price2 = 0
      assign compare_at_price2 = 0
      assign save2 = 0
    
      assign price3 = 0
      assign compare_at_price3 = 0
      assign save3 = 0
    
      assign base_price = product.selected_or_first_available_variant.price
       
      assign discount_rate_1 = 0.35
      assign discount_amount_1 = base_price | times: discount_rate_1
      assign final_price_1 = base_price | minus: discount_amount_1
    
      assign price1 = final_price_1
      assign compare_at_price1 = base_price
      assign save1 = discount_rate_1 | times: 100 | round
    
      assign discount_rate_2 = 0.40
      assign discount_amount_2 = base_price | times: discount_rate_2
      assign final_price_2 = base_price | minus: discount_amount_2
        
      assign price2 = final_price_2
      assign compare_at_price2 = base_price
      assign save2 = discount_rate_2 | times: 100 | round
    
      assign discount_rate_3 = 0.45
      assign discount_amount_3 = base_price | times: discount_rate_3
      assign final_price_3 = base_price | minus: discount_amount_3

      assign price3 = final_price_3
      assign compare_at_price3 = base_price 
      assign save3 = discount_rate_3 | times: 100 | round
    -%}
    <div class="qty_selector_discount">
      <div class="qty_selector_discount_title"><span>→ OFFER ENDS AT 23:59 ←</span></div>
      {%- if price1 > 0 -%}
        <div class="quantity_selector">
          <div
            class="single_quantity"
            data-qty="1"
            data-price="{{ price1 | money }}"
            data-old-price="{{ compare_at_price1 | money_without_trailing_zeros }}"
          >  
            <img src="https://cdn.shopify.com/s/files/1/0283/8190/4984/files/led_1.png?v=1741853737"/>
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">1 Ball</h4>
                <div class="sq_you_save">
                  {%- if product.tags contains 'bogo-deal' -%}
                    Buy 1, Get 1 - Mix and Match
                  {%- else -%}
                    Save {{ save1 }}%
                  {%- endif -%}
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price notranslate ht-money" style="margin-bottom: 0px;">{{ price1 | money }}</h6>
                <h6 class="quanity-prc notranslate ht-money" style="margin-bottom: 0px;">
                  was <span>{{ compare_at_price1 | money_without_trailing_zeros }}</span>
                </h6>
              </div>
            </div>
          </div>
  
          <div
            class="single_quantity selected firstclick"
            data-qty="2"
            data-price="{{ price2 | money }}"
            data-old-price="{{ compare_at_price2 | money_without_trailing_zeros }}"
          >  
            <img src="https://cdn.shopify.com/s/files/1/0283/8190/4984/files/led_2.png?v=1741853737"/>
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">
                  2 Balls
                  <div class="single_quantity_main_left_gratis">Free Shipping</div>
                </h4>
                <div class="sq_you_save">
                  {%- if product.tags contains 'bogo-deal' -%}
                    Buy 1 Get 1 for Free
                  {%- else -%}
                    Save {{ save2 }}%
                  {%- endif -%}
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price notranslate ht-money" style="margin-bottom: 0px;">{{ price2 | money }}</h6>
                <h6 class="quanity-prc notranslate ht-money" style="margin-bottom: 0px;">
                  was <span>{{ compare_at_price2 | money_without_trailing_zeros }}</span>
                </h6>
              </div>
            </div>
  
            <div class="most-popular">🔥 Most Popular</div>
          </div>
  
          <div
            class="single_quantity"
            data-qty="{% if product.tags contains 'bogo-deal'%}4{% else %}3{% endif %}"
            data-price="{{ price3 | money }}"
            data-old-price="{{ compare_at_price3 | money_without_trailing_zeros }}"
          >  
            <img src="https://cdn.shopify.com/s/files/1/0283/8190/4984/files/led_3.png?v=1741853737"/>
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">
                  {% if product.tags contains 'bogo-deal'%}4{% else %}3{% endif %} Balls
                  <div class="single_quantity_main_left_gratis beste_deal">Best Deal</div>
                </h4>
                <div class="sq_you_save">
                  {%- if product.tags contains 'bogo-deal' -%}
                    Buy 2 Get 2 for Free
                  {%- else -%}
                    Save {{ save3 }}%
                  {%- endif -%}
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price notranslate ht-money" style="margin-bottom: 0px;">
                  {{ price3 | money }}
                </h6>
                <h6 class="quanity-prc notranslate ht-money" style="margin-bottom: 0px;">
                  was <span>{{ compare_at_price3 | money_without_trailing_zeros }}</span>
                </h6>
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="quantity_selector">
          {% assign dis_price_one = selected_variant.price | times: 22.33 | divided_by: 100.0 | round %}
          {% assign get_discount_price_one = selected_variant.price | minus: dis_price_one %}
  
          {% assign discount_price_1 = get_discount_price_one | plus: 0 %}
          {% assign original_price_1 = selected_variant.price | plus: 0 %}
  
          {% assign discount_percentage1 = discount_price_1 | times: 100 | divided_by: original_price_1 %}
          {% assign discount_percentage1 = 100 | minus: discount_percentage1 %}
          {% assign discount_percentage1 = discount_percentage1 | round %}
          <div
            class="single_quantity"
            data-qty="1"
            data-price="{{ get_discount_price_one | money }}"
            data-old-price="{{ selected_variant.price | money }}"
          >
            <div class="option_radio_custom"></div>
  
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">1 Bal</h4>
                <div class="sq_you_save">Save {{ discount_percentage1 }}% on your total order!</div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">{{ get_discount_price_one | money }}</h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.price | money }}</span>
                </h6>
              </div>
            </div>
          </div>
  
          {% assign dis_price_two = selected_variant.price | times: 65 | divided_by: 100 | round %}
          {% assign get_discount_price_two = selected_variant.price | minus: dis_price_two %}
  
          {% assign discount_price_2 = get_discount_price_two | plus: 0 %}
          {% assign original_price_2 = selected_variant.price | plus: 0 %}
  
          {% assign discount_percentage2 = discount_price_2 | times: 100 | divided_by: original_price_2 %}
          {% assign discount_percentage2 = 100 | minus: discount_percentage2 %}
          {% assign discount_percentage2 = discount_percentage2 | round %}
  
          <div
            class="single_quantity selected firstclick"
            data-qty="2"
            data-price="{{ get_discount_price_two | times: 2 | money }}"
            data-old-price="{{ selected_variant.price | times: 2 | money }}"
          >
            <div class="option_radio_custom"></div>
  
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">
                  2 Ballen
                  <div class="single_quantity_main_left_gratis">Gratis Verzending</div>
                </h4>
                <div class="sq_you_save">Save {{ discount_percentage2 }}% on your total order!</div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">{{ get_discount_price_two | times: 2 | money }}</h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.price | times: 2 | money }}</span>
                </h6>
              </div>
            </div>
  
            <div class="most-popular">🔥 Meest populair</div>
          </div>
  
          {% assign dis_price_three = selected_variant.price | times: 70 | divided_by: 100.0 | round %}
          {% assign get_discount_price_three = selected_variant.price | minus: dis_price_three %}
  
          {% assign discount_price_3 = get_discount_price_three | plus: 0 %}
          {% assign original_price_3 = selected_variant.price | plus: 0 %}
  
          {% assign discount_percentage3 = discount_price_3 | times: 100 | divided_by: original_price_3 %}
          {% assign discount_percentage3 = 100 | minus: discount_percentage3 %}
          {% assign discount_percentage3 = discount_percentage3 | round %}
  
          <div
            class="single_quantity"
            data-qty="3"
            data-price="{{ get_discount_price_three | times: 3 | money }}"
            data-old-price="{{ selected_variant.price | times: 3 | money }}"
          >
            <div class="option_radio_custom"></div>
  
            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">
                  3 Ballen
                  <div class="single_quantity_main_left_gratis">Beste Deal</div>
                </h4>
                <div class="sq_you_save">Save {{ discount_percentage3 }}% on your total order!</div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">
                  {{ get_discount_price_three | times: 3 | money }}
                </h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.price | times: 3 | money }}</span>
                </h6>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  {% else %}
    {% unless product.handle == 'the-bright-air-pump' %}
      {% if flag_offer %}
        <div class="qty_selector_discount">
          <label style="margin-bottom: 55px; display: block; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; font-size: 12px;"
            >Aantal</label
          >
          <div class="quantity_selector">
            <div class="single_quantity selected" data-qty="1">
              <div class="option_radio_custom"></div>
              <h4 class="h4">1</h4>
              <h6
                class="h6 discounttag"
                data-oprice="{{ selected_variant.price | minus:1000 | money }}"
              >
                Bespaar {{ 1000 | money_without_trailing_zeros }}
              </h6>
            </div>
            <div class="option_radio_custom"></div>
            <h4 class="h4">2</h4>
            {% assign selected_vn_price = selected_variant.price | minus: 300 | times: 2 %}
            <h6
              class="h6 discounttag hasdiscount"
              data-oprice="{{ selected_variant.price | minus: 1300  | money }}"
            >
              Bespaar {{ 2600 | money_without_trailing_zeros }}
            </h6>
          </div>
          <div class="single_quantity" data-qty="3">
            <div class="option_radio_custom"></div>
            <h4 class="h4">3</h4>
            <h6
              class="h6 discounttag hasdiscount"
              data-oprice="{{ selected_variant.price | minus: 1500 | money }}"
            >
              Bespaar {{ 4500 | money_without_trailing_zeros }}
            </h6>
          </div>
        </div>
        </div>
      {% endif %}

      {% if flag_offer2 %}
        <div class="qty_selector_discount_old">
          <label style="margin-bottom: 55px; display: block; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; font-size: 12px;"
            >Aantal</label
          >
          <div class="quantity_selector">
            <div class="single_quantity selected" data-qty="1">
              <div class="option_radio_custom"></div>

              <h4 class="h4">1</h4>
              <h6 class="h6 discounttag" data-oprice="{{ selected_variant.price | money }}"></h6>
            </div>
            <div class="single_quantity" data-qty="2">
              <div class="option_radio_custom"></div>

              <h4 class="h4">2</h4>
              {% assign selected_vn_price = selected_variant.price | minus: 400 | times: 2 %}
              {% assign top_price = selected_variant.price | times: 2 %}
              {% assign selected_nt_price = top_price | minus: selected_vn_price %}
              <h6
                class="h6 discounttag hasdiscount"
                data-oprice="{{ selected_variant.price | minus: 400  | money }}"
              >
                10% korting
              </h6>
            </div>
            <div class="single_quantity" data-qty="3">
              <div class="option_radio_custom"></div>
              <h4 class="h4">3</h4>
              {% assign selected_vn_b_price = selected_variant.price | minus: 600 | times: 3 %}
              {% assign top_price = selected_variant.price | times: 3 %}
              {% assign selected_nb_price = top_price | minus: selected_vn_b_price %}

              <h6
                class="h6 discounttag hasdiscount"
                data-oprice="{{ selected_variant.price | minus: 600  | money }}"
              >
                15% korting
              </h6>
            </div>
          </div>
        </div>
      {% endif %}

      {% if flag_offer3 %}
        <div class="qty_selector_discount_old">
          <label style="margin-bottom: 55px; display: block; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; font-size: 12px;"
            >Aantal</label
          >
          <div class="quantity_selector">
            <div class="single_quantity selected" data-qty="1">
              <div class="option_radio_custom"></div>
              <h4 class="h4">1</h4>
              <h6 class="h6 discounttag" data-oprice="{{ selected_variant.price | money }}"></h6>
            </div>
            <div class="single_quantity" data-qty="2">
              <div class="option_radio_custom"></div>
              <h4 class="h4">2</h4>
              {% assign selected_vn_price = selected_variant.price | minus: 300 | times: 2 %}
              <h6
                class="h6 discounttag hasdiscount"
                data-oprice="{{ selected_variant.price | minus: 300  | money }}"
              >
                10% korting
              </h6>
            </div>
            <div class="single_quantity" data-qty="3">
              <div class="option_radio_custom"></div>
              <h4 class="h4">3</h4>
              <h6
                class="h6 discounttag hasdiscount"
                data-oprice="{{ selected_variant.price | minus: 500  | money }}"
              >
                15% korting
              </h6>
            </div>
          </div>
        </div>
      {% endif %}
    {% endunless %}
  {% endif %}

  <input type="hidden" id="variant-id" name="id" value="{{ product.selected_or_first_available_variant.id }}">

  <div class="ProductForm__Variants">
    {%- unless product.has_only_default_variant -%}
      <div class="ProductForm__Option">
        {% if product.options_by_name.Maat and product.options_by_name.Maat.values %}
          <div class="product-options">
            <div class="product-options-label">Size</div>
            {% for value in product.options_by_name.Maat.values %}
              <input
                type="radio"
                name="size"
                id="size{{ forloop.index }}"
                value="{{ value | escape }}"
                {% if forloop.first %}
                  checked
                {% endif %}
              >
              <label for="size{{ forloop.index }}">{{ value }}</label>
            {% endfor %}
          </div>
        {% endif %}

        {% if product.options_by_name.Color and product.options_by_name.Color.values %}
          <div class="product-options">
            <div class="product-options-label">Color</div>
            {% for value in product.options_by_name.Color.values %}
              <input
                type="radio"
                name="color"
                id="color{{ forloop.index }}"
                value="{{ value | escape }}"
                {% if forloop.first %}
                  checked
                {% endif %}
              >
              <label for="color{{ forloop.index }}">{{ value }}</label>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="qty_selector_discount">
        <div class="qty_selector_discount_title"><span>→ AANBIEDING EINDIGT OM 23:59 ←</span></div>
        <div class="quantity_selector">
          {% assign dis_price_one = selected_variant.compare_at_price | minus: selected_variant.price %}

          <div
            class="single_quantity"
            data-qty="1"
            data-price="{{ selected_variant.price | money }}"
            data-old-price="{{ selected_variant.compare_at_price | money }}"
          >
            <div class="option_radio_custom"></div>

            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">1 Product</h4>
                <div class="sq_you_save">
                  Bespaar <span>{{ dis_price_one | money }}</span>
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">{{ selected_variant.price | money }}</h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.compare_at_price | money }}</span>
                </h6>
              </div>
            </div>
          </div>

          <div
            class="single_quantity selected firstclick"
            data-qty="2"
            data-price="{{ selected_variant.price | times: 2 | money }}"
            data-old-price="{{ selected_variant.compare_at_price | times: 2 | money }}"
          >
            <div class="option_radio_custom"></div>

            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">2 Products</h4>
                <div class="sq_you_save">
                  Slechts <span>{{ selected_variant.price | money }}/pair</span>
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">
                  {{ selected_variant.price | times: 2 | money }}
                </h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.compare_at_price | times: 2 | money }}</span>
                </h6>
              </div>
            </div>

            <div class="most-popular">🔥 Meest populair</div>
          </div>

          {% assign saleval_3 = 100
            | minus: selected_variant.price
            | times: 100
            | divided_by: selected_variant.compare_at_price
          %}
          {% assign saleval_3 = saleval_3 | round %}

          <div
            class="single_quantity"
            data-qty="3"
            data-price="{{ selected_variant.price | times: 3 | money }}"
            data-old-price="{{ selected_variant.compare_at_price | times: 3 | money }}"
          >
            <div class="option_radio_custom"></div>

            <div class="single_quantity_main">
              <div class="single_quantity_main_left">
                <h4 class="h4">3 Products</h4>
                <div class="sq_you_save">
                  <span>Save {{ saleval_3 }}% on your total order!</span>
                </div>
              </div>
              <div class="single_quantity_main_right">
                <h6 class="quanity-price" style="margin-bottom: 0px;">
                  {{ selected_variant.price | times: 3 | money }}
                </h6>
                <h6 class="quanity-prc" style="margin-bottom: 0px;">
                  was <span>{{ selected_variant.compare_at_price | times: 3 | money }}</span>
                </h6>
              </div>
            </div>

            <div class="most-popular best-deal">💎 Beste deal</div>
          </div>
        </div>
      </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          var productForm = document.getElementById('product_form_{{ product.id }}');
          var variants = {{ product.variants | json }};

          function updateVariant(selectedOptions) {
            var selectedVariant = variants.find(function(variant) {

              {% if product.options_by_name['Color'] and product.options_by_name['Color'].values %}
                return selectedOptions.size === variant.option1 && selectedOptions.color === variant.option2;
              {% else %}
                return selectedOptions.size === variant.option1;
              {% endif %}
            });

            if (selectedVariant) {
              $("#variant-id").val(selectedVariant.id);
            }
          }

          var radioInputs = productForm.querySelectorAll('input[type="radio"]');
          radioInputs.forEach(function(radio) {
            radio.addEventListener('change', function() {
              var selectedOptions = {
                size: productForm.querySelector('input[name="size"]:checked').value

                {% if product.options_by_name['Color'] and product.options_by_name['Color'].values %}
                  ,color: productForm.querySelector('input[name="color"]:checked').value
                {% endif %}
              };
              updateVariant(selectedOptions);
            });
          });

          var defaultOptions = {
            size: productForm.querySelector('input[name="size"]:checked').value

            {% if product.options_by_name['Color'] and product.options_by_name['Color'].values %}
              ,color: productForm.querySelector('input[name="color"]:checked').value
            {% endif %}
          };
          updateVariant(defaultOptions);
        });
      </script>
    {%- else -%}
      <input
        type="hidden"
        name="id"
        data-sku="{{ selected_variant.sku }}"
        value="{{ selected_variant.id }}"
      >
    {%- endunless -%}

    {%- if section.settings.show_quantity_selector -%}
      <div class="ProductForm__QuantitySelector">
        <div class="QuantitySelector QuantitySelector--large">
          {%- assign quantity_minus_one = line_item.quantity | minus: 1 -%}

          <span
            class="QuantitySelector__Button Link Link--secondary"
            data-action="decrease-quantity"
          >
            {%- include 'icon' with 'minus' -%}
          </span>
          <input
            type="text"
            class="QuantitySelector__CurrentQuantity"
            pattern="[0-9]*"
            name="quantity"
            value="1"
          >
          <span
            class="QuantitySelector__Button Link Link--secondary"
            data-action="increase-quantity"
          >
            {%- include 'icon' with 'plus' -%}
          </span>
        </div>
      </div>
    {%- else -%}
      <input type="hidden" name="quantity" value="1" class="pass_qty_hidden">
    {%- endif -%}

    {%- if section.settings.show_inventory_quantity -%}
      {%- assign hide_inventory_quantity_by_default = false -%}

      {%- if selected_variant.inventory_management == blank or selected_variant.inventory_quantity <= 0 -%}
        {%- assign hide_inventory_quantity_by_default = true -%}
      {%- endif -%}

      {%- if section.settings.inventory_quantity_threshold != 0
        and selected_variant.inventory_quantity > section.settings.inventory_quantity_threshold
      -%}
        {%- assign hide_inventory_quantity_by_default = true -%}
      {%- endif -%}

      <p
        class="ProductForm__Inventory Text--subdued"
        {% if hide_inventory_quantity_by_default %}
          style="display: none"
        {% endif %}
      >
        {%- if section.settings.inventory_quantity_threshold == 0 -%}
          {{- 'product.form.inventory_quantity_count' | t: count: selected_variant.inventory_quantity -}}
        {%- else -%}
          {{- 'product.form.low_inventory_quantity_count' | t: count: selected_variant.inventory_quantity -}}
        {%- endif -%}
      </p>
    {%- endif -%}
  </div>

  {%- comment -%}
    --------------------------------------------------------------------------------------------------------------------
    ADD TO CART BUTTON
    --------------------------------------------------------------------------------------------------------------------
  {%- endcomment -%}

  <button
    style="min-height: 56px;justify-content:center;column-gap:10px;"
