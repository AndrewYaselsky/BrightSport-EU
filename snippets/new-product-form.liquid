</script>

<script>
  let added = false;
  let quantity = 1;

  document.querySelectorAll('div[data-qty]').forEach((el) => {
    el.addEventListener('click', () => {
      quantity = parseInt(el.getAttribute('data-qty'));
    });
  });

  const atcBtn = document.querySelector('.ProductForm__AddToCart');
  const text = atcBtn.querySelector('span');

  atcBtn.addEventListener('click', async (e) => {

    var variantid = $("#variant-id").val();

    text.innerText = '{{section.settings.cart-button-before-text}}';

    await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        items: [{ id: variantid, quantity }],
      }),
    });

    atcBtn.classList.add('added');

    added = true;
    text.innerText = '{{section.settings.cart-button-after-text}}';

    if (added) return openCart();

    updateTopCartCount();
    rerenderCart();
  });


  $(".single_quantity").on("click", function(){
    $(".changable_price_main").html($(this).data("price"));

     var price = $(".changable_price_main1").html($(this).data("price")); // Change to your actual element class

    // Divide the price by 4
    var dividedPrice = price / 4;

    // Update the HTML of the element
    $(".changable_price_main2").html(dividedPrice.toFixed(2));


    $(".changable_price_main1").html($(this).data("price"));
    $(".compare_at_price_main").html("<b>was</b> <p>" + $(this).data("old-price") + "</p>");
    $(".sticky_product_name_after_current").html($(this).data("price"));
    $(".sticky_product_name_after_old").html("<b>was</b> " + $(this).data("old-price"));

    var prices = $(this).data("price");
    var vals = $(this).data("old-price");

    var saleval = 100 - (Number(prices.replace(/[^0-9.-]+/g,"")) * 100 / Number(vals.replace(/[^0-9.-]+/g,"")));
    saleval = Math.round(saleval);

    $(".sticky_product_name_percent").text(saleval + "%");
  });
</script>

