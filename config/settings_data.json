      "product-faq-section": {
        "type": "product-faq-section",
        "blocks": {
          "0a11589f-1946-4e07-8172-774ab8cd29fc": {
            "type": "faq",
            "settings": {
              "faq-question": "What are the delivery times?",
              "faq-answer": "<p><strong>Netherlands/Belgium: </strong>1-3 business days</p><p><strong>Rest of Europe:</strong> 2-4 business days</p><p><strong>Rest of the World:</strong> 3-5 business days</p><p><strong>Free shipping on orders from €60</strong></p><p>All orders ship via DHL and PostNL. A tracking link is emailed once your order is processed.</p>"
            }
          },
          "1de18365-b29b-4f77-aadb-181b32ab754c": {
            "type": "faq",
            "settings": {
              "faq-question": "How does it work?",
              "faq-answer": "<p>Our viral BRIGHT® ball uses glow technology—it lights up when it catches light. Think of your phone camera flash. When you take a photo or video, the ball appears to glow on your screen. It is a stunning effect that grabs everyone's attention!</p>"
            }
          },
          "c09e0eb9-1c47-4e29-ad39-dd733e5a65ad": {
            "type": "faq",
            "settings": {
              "faq-question": "Can the ball be used both indoors and outdoors?",
              "faq-answer": "<p>With the BRIGHT ball you get endless fun—it works both indoors and outdoors!</p><p>Whether you are on the pitch or playing at home, the BRIGHT ball adapts to every situation.</p>"
            }
          },
          "734b272b-6e93-4a35-ba3c-c1a3a1f6b486": {
            "type": "faq",
            "settings": {
              "faq-question": "Can you clean the ball?",
              "faq-answer": "<p>Keeping the glow effect is easy! Simply wipe with a damp cloth—avoid harsh cleaners or submerging in water.</p>"
            }
          },
          "a885519e-b7aa-47dd-aca1-b71615ae2d00": {
            "type": "faq",
            "settings": {
              "faq-question": "What if I don't like my product?",
              "faq-answer": "<p>We are confident you will love the product! If not, we offer a 30-day money-back guarantee. If you are not 100% satisfied for any reason, simply return it for a refund or exchange.</p>"
            }
          },
          "486b5803-2a63-4619-9d39-7443a7056a72": {
            "type": "faq",
            "settings": {
              "faq-question": "Do you offer worldwide shipping?",
              "faq-answer": "<p>Enjoy the BRIGHT® ball wherever you are! Our worldwide shipping brings this product to you wherever you live. Shipping costs and delivery times may vary by location.</p>"
            }
          },
          "9e0df131-e15e-43f3-b3e5-8df1b7243752": {
            "type": "faq",
            "settings": {
              "faq-question": "Do you have a question?",
