      "sw--you--answers": {
        "type": "sw--you--answers",
        "blocks": {
          "16821ee5-36c7-42cb-87ce-1530d81c2679": {
            "type": "accordian",
            "settings": {
              "question": "How does the ball glow?",
              "answer": "<p>It is made from holographic material that catches and reflects light. When you take a photo or video with flash on, the ball creates a glow effect on your screen. This stunning effect is even visible in daylight!</p>"
            }
          },
          "f588f843-75b6-4caf-ae2b-0e423b456d4d": {
            "type": "accordian",
            "settings": {
              "question": "How long until I receive my order?",
              "answer": "<p>Orders are usually processed within 1-2 days. Delivery takes 3 to 5 business days.</p>"
            }
          },
          "a30cfe2d-fe87-4f20-8a0f-d5942a10efcd": {
            "type": "accordian",
            "settings": {
              "question": "Can the ball be used indoors and outdoors?",
              "answer": "<p>Yes, it is suitable for both indoor and outdoor play.</p>"
            }
          },
          "d14e1957-9bc0-490d-aef8-8359276d0a33": {
            "type": "accordian",
            "settings": {
              "question": "Can you clean the ball?",
              "answer": "<p>Yes, you can clean it with a clean, damp cloth without harsh cleaners.</p>"
            }
          },
          "1188d6d8-ff63-479f-89b3-5a4c2b780c07": {
            "type": "accordian",
            "settings": {
              "question": "What material are these balls made of?",
              "answer": "<p>It is made from holographic leather.</p>"
            }
          },
          "9a10a8e0-d1c2-4cd2-aafe-94d4cdf60337": {
            "type": "accordian",
            "settings": {
              "question": "Can I personalize my product?",
              "answer": "<p>Yes! We can personalize our balls with your branding, but the BRIGHT logo and name remain visible. A minimum order quantity is required. Fill out this <a href=\"/pages/dev-contact-us\" title=\"Dev Contact Us\"><strong>contact form</strong></a> to request pricing.</p>"
            }
          }
        },
