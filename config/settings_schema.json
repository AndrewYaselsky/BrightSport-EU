  {
    "name": {
      "en": "Mamuta Smarty App"
    },
    "settings": [
      {
        "type": "header",
        "content": {
          "en": "Product page"
        }
      },
      {
        "type": "radio",
        "id": "mamuta_product_box_position",
        "label": "Campaigns info position",
        "options": [
          {
            "value": "before",
            "label": "Before 'Add to Cart' button"
          },
          {
            "value": "after",
            "label": "After 'Add to Cart' button"
          },
          {
            "value": "none",
            "label": "DO NOT Display"
          }
        ],
        "default": "after"
      },
      {
        "type": "range",
        "id": "mamuta_product_box_width",
        "label": "Campaigns info relative width",
