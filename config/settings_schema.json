        "default": 8,
        "min": -20,
        "max": 80,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "radio",
        "id": "mamuta_product_description_align",
        "label": "Campaign description alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          },
