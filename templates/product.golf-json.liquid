  <script>
  var swiperButtons = new Swiper("#productGalleryButtons", {
    loop: false,
    direction: 'vertical',
    spaceBetween: 8,
    slidesPerView: 5,
    freeMode: false,
    allowTouchMove: false,
    centeredSlides: false,
    // Enable lazy loading
    lazy: true,
    keyboard: {
      enabled: true,
    },
  });
  var mySwiper = new Swiper ('#productGallery', {
    // Optional parameters
    spaceBetween: 16,
    slidesPerView: 1,
    loop: true,
    effect: 'fade',
    thumbs: {
      swiper: swiperButtons,
    },
    pagination: {
      el: '#productPagination',
      type: 'bullets',
    }
  });

  function updatePrices(click__butt) {
    var $clickButton = $(click__butt);
    var prc = $clickButton.data("prc");
    var price = $clickButton.data("price");
    var comPrice = $clickButton.data("com-price");
    var prid = $clickButton.data("id");
    var $mainComPrice = $("#main-com-price");
    var $ATCComPrice = $("#ATC_com_price");
    var $productHeaderPrice = $(".product-header1_price_difference");
    var $cta_price_difference = $(".cta_price_difference");
    
    $mainComPrice.html(comPrice);
    $ATCComPrice.html(comPrice);
    $("#main-price, #main_price_in_button").html(price);
    $("#ATC_price").html(price);
    $("#product-select-8340685259077").val(prid);
  
    if (prc === "100%") {
      $mainComPrice.add($productHeaderPrice).fadeOut();
      $ATCComPrice.add($cta_price_difference).fadeOut();
    } else {
      $mainComPrice.add($productHeaderPrice).fadeIn();
      $ATCComPrice.add($cta_price_difference).fadeIn();
      $("#main-prc").html(prc);
      $("#ATC-prc").html(prc);
    }
  }
  
  $(document).ready(function() {
    updatePrices(".w--redirected-checked");
  });
  
  $(".w-form-formradioinput").on("click", function() {
    updatePrices(this);
    $(".w-form-formradioinput").removeClass("w--redirected-checked");
    $(this).addClass("w--redirected-checked");
  });
</script>