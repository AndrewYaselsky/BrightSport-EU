<div class="container">
  <div class="dev_contact_main">
    <div class="dev_contact_info">
      {% if section.settings.title != blank %}
        <h2 class="dev_contact_title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.cap != blank %}
        <p class="dev_contact_caption">{{ section.settings.cap }}</p>
      {% endif %}
    </div>
    <div class="dev_contact_form">
      {%- form 'contact', class: 'Form Form--spacingTight' -%}
        {%- if form.posted_successfully? -%}
          <p class="Alert Alert--success">{{ 'contact.form.successfully_sent' | t }}</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="Form__Alert Alert Alert--error">
            <ul class="Alert__ErrorList">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <li class="Alert__ErrorItem">{{ form.errors.messages[field] }}</li>
                {%- else -%}
                  <li class="Alert__ErrorItem"><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="dev_contact_form_Group">
          <div class="dev_contact_form_Item">
            <input type="text" class="dev_contact_form_Input" name="contact[name]" aria-label="{{ 'contact.form.name' | t }}" placeholder="{{ 'contact.form.placeholder_name' | t }}" required {% if customer %}value="{{ customer.name }}"{% endif %}>
            <label class="dev_contact_form_FloatingLabel">{{ 'contact.form.name' | t }}</label>
          </div>

          <div class="dev_contact_form_Item">
            <input type="email" class="dev_contact_form_Input" name="contact[email]" aria-label="{{ 'contact.form.email' | t }}" placeholder="{{ 'contact.form.placeholder_email' | t }}" required {% if customer %}value="{{ customer.email }}"{% endif %}>
            <label class="dev_contact_form_FloatingLabel">{{ 'contact.form.email' | t }}</label>
          </div>
        </div>

        <div class="dev_contact_form_Item">
          <input type="number" class="dev_contact_form_Input" name="contact[phone]" aria-label="{{ 'contact.form.phone' | t }}" placeholder="{{ 'contact.form.placeholder_phone' | t }}" required {% if customer %}value="{{ customer.phone }}"{% endif %}>
          <label class="dev_contact_form_FloatingLabel">{{ 'contact.form.phone' | t }}</label>
        </div>

        <div class="dev_contact_form_Item">
          <textarea name="contact[body]" cols="30" rows="5" class="dev_contact_form_Textarea" aria-label="{{ 'contact.form.message' | t }}" placeholder="{{ 'contact.form.placeholder_message' | t }}" required></textarea>
          <label class="dev_contact_form_FloatingLabel">{{ 'contact.form.message' | t }}</label>
        </div>

        <button type="submit" class="dev_contact_form_Submit new_common_btn Button--full">{{ 'contact.form.submit' | t }}
          <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18.4647 1.42579L16.2147 16.0156C16.1796 16.3672 15.9686 16.6836 15.6522 16.8594C15.4764 16.9297 15.3007 17 15.0897 17C14.9491 17 14.8085 16.9649 14.6679 16.8945L10.3788 15.1016L8.58582 17.7734C8.4452 18.0195 8.19911 18.125 7.95301 18.125C7.56629 18.125 7.24989 17.8086 7.24989 17.4219V14.0469C7.24989 13.7656 7.3202 13.5195 7.46082 13.3438L15.1249 3.50001L4.78895 12.8164L1.16786 11.3047C0.781137 11.1289 0.499887 10.7774 0.499887 10.3203C0.46473 9.82813 0.675668 9.47657 1.06239 9.26563L16.8124 0.300791C17.1639 0.0898534 17.6561 0.0898534 18.0077 0.335947C18.3593 0.582041 18.535 1.00392 18.4647 1.42579Z" fill="currentColor"/>
          </svg>
        </button>
      {%- endform -%}
    </div>
  </div>
</div>


<script>

</script>


{% schema %}
  {
    "name": "Dev Contact",
    "class": "sw--dev-contact",
    "settings": [
      {
        "type": "textarea",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "textarea",
        "id": "cap",
        "label": "Caption"
      }
    ],
    "presets":[
      {
        "name": "Dev Contact"        
      }
    ]
  }
{% endschema %}