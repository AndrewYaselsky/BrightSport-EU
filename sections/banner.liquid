{% if section.settings.enabled_banner %}
  <section id="section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="slideshow">
    <div class="container">
      <a href="/collections/all">
        {%- assign mobile_image = section.settings.mobile_image | default: section.settings.image -%}
        {%- if mobile_image -%}
          <div class="Slideshow__ImageContainer  hidden-tablet-and-up">
            <img
              class="Slideshow__Image banner__Image Image--lazyLoad"
              src="{{ mobile_image | image_url: width: 1200 | split: '?v' | first }}"
            >
          </div>
        {%- endif -%}
        {%- if section.settings.image -%}
          <div class="Slideshow__ImageContainer hidden-phone">
            <img
              class="Slideshow__Image banner__Image Image--lazyLoad hide-no-js"
              src="{{ section.settings.image | image_url: width: 1200 | split: '?v' | first }}"
            >
          </div>
        {%- else -%}
          <div class="Slideshow__ImageContainer PlaceholderSvg--dark">
            {%- capture placeholder -%}{% cycle 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
            {{ placeholder | placeholder_svg_tag: 'Slideshow__Image PlaceholderBackground__Svg' }}
          </div>
        {%- endif -%}
      </a>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Banner",
  "class": "shopify-section--slideshow breadcrumb_banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled_banner",
      "label": "Enable",
      "default": true
    },
    {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop Image",
          "info": "1560 x 1050px jpg recommended"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image",
          "info": "750 x 1100px jpg recommended. If none is set, desktop image will be cropped."
        }
  ]
}
{% endschema %}
