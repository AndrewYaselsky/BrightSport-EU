                     </svg>
                  </a>
               </div>
            </div>
            {% endif %}
            <div class="megamenu_bottom_col">
               {% for i in (1..6) %}
               {% capture megamenu_right_image %}megamenu_right_image{{i}}{% endcapture %}
               {% capture right_sub_title %}right_sub_title{{i}}{% endcapture %}
