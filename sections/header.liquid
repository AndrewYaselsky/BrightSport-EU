        class="Header__Icon Icon-Wrapper Icon-Wrapper--clickable {% unless use_sidebar_menu %}hidden-desk{% endunless %}"
        {% if settings.cart_type == 'drawer' %}data-action="open-drawer"data-drawer-id="sidebar-cart"aria-expanded="false"aria-label="{{ 'header.navigation.open_cart' | t }}"{% endif %}>
