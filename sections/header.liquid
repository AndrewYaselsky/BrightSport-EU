<style>

  {%- unless template == 'index' or template == 'templates' -%}
    #main {
      padding-top: 103px;
    }

    @media screen and (max-width: 767px) {
      #main {
        padding-top: 86px;
      }
    }
  {%- endunless -%}

  .shopify-section--header {
    transform: translate3d(0, -101%, 1px);
    -webkit-transform: translate3d(0, -101%, 1px);
    transition: transform 0.35s ease-in-out;
    position: relative;
  }

  .sticky-header {

    transform: translate3d(0, 0, 1px);
    -webkit-transform: translate3d(0, 0, 1px);
    transition: transform 0.35s ease-in-out;

  }
  .header-no-shadow #section-header {
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
  }
  .transparent-header #section-header {
    background: transparent;
  }
  {%- if section.settings.use_sticky_header -%}
    :root  {
      --use-sticky-header: 1;
    }

    .shopify-section--header {
      position: fixed;
    }
  {%- endif -%}

  {%- if use_transparent_header -%}
    :root  {
      --header-is-not-transparent: 0;
      --header-is-transparent: 1;
    }

    .shopify-section--header {
      margin-bottom: calc(-1 * var(--header-height));
    }

    .supports-sticky .Header--transparent {
      box-shadow: 0 -1px{{ section.settings.transparent_text_color | color_modify: 'alpha', 0.25 }}inset;
      color: {{ section.settings.transparent_text_color }}
      ;
    }
  {%- else -%}
    :root  {
      --header-is-not-transparent: 1;
      --header-is-transparent: 0;
    }
  {%- endif -%}
</style>

<script>
  document.documentElement.style.setProperty('--header-height', document.getElementById('shopify-section-header').offsetHeight + 'px');

  $(window).scroll(function() {
   if($("body").hasClass("template-product")){
    var scrollTop = $(window).scrollTop();
    if ( scrollTop > 1 ) { 
     $(".last_chance_bar").css('display', 'flex');
      $(".AnnouncementBar").css('display', 'none');
    }else{
     $(".last_chance_bar").css('display', 'none');
      $(".AnnouncementBar").css('display', 'block');
    }
   }
  });

</script>

