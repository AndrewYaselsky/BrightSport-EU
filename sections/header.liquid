          <div class="header_center_box">
            <div class="header_center_box_text">
              <div class="header_center_box__marquee">
                <div class="header_center_box__marquee-track">
                  {%- for i in (1..3) -%}
                    <div>{{ settings.annotext }}</div>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </div>
        </div>
    </div>
  </div>
</div>

    
