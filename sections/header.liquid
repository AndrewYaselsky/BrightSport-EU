                     </svg>
                  </a>
               </div>
            </div>
            {% endif %}
            <div class="megamenu_bottom_col">
               {% for i in (1..6) %}
               {% capture megamenu_image %}megamenu_image{{i}}{% endcapture %}
               {% capture sub_title %}sub_title{{i}}{% endcapture %}
               {% capture product_url %}product_url{{i}}{% endcapture %}
               {% capture label_checkbox %}label_checkbox{{i}}{% endcapture %}
               <div class="megamenu_bottom_box menu_sub_box{{ forloop.index }}">
