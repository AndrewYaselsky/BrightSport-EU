                     {% if block.settings[megamenu_image] != blank %}
                     <div class="megamenu_image">
                        <a href="{{ block.settings[product_url] }}">
                        <img src="{{ block.settings[megamenu_image] | img_url:'master' }}">
                        </a>
                     </div>
                     {% endif %}
                     {% if block.settings[sub_title] != blank %}
                     <div class="megamenu_image_text">
                        <a href="{{ block.settings[product_url] }}">
                           <p>{{ block.settings[sub_title] }}</p>
                        </a>
                     </div>
                     {% endif %}
                     {% if block.settings[label_checkbox] %}
                     <div class="new_label">
                        <span>New</span>
                     </div>
                     {% endif %}
                  </div>
               </div>
               {% endfor %}
            </div>
         </div>
      </div>
   </div>
   <div class="megamenu_box">
      <div class="megamenu_box_in">
         <div class="megamenu_box_in_col">
            {% if block.settings.megamenu_main_title2 != blank or block.settings.see_all_btn2 != blank %}
            <div class="megamenu_top_col">
               <div class="megamenu_title">{{ block.settings.megamenu_main_title2 }}</div>
