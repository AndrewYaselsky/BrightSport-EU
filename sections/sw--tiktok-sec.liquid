<section>
  <div class="tiktok_wrapper">
    <div class="container_tiktok">
      <div class="tiktok_col">
        {% if section.settings.top_heading != blank or section.settings.top_icon != blank %}
        <div class="tittok_top_heading">
          <span>{{ section.settings.top_icon }}</span>
          <h6>{{ section.settings.top_heading  }}</h6>
        </div>
          {% endif  %}
        {% if section.settings.main_heading != blank %}
          <div class="tiktok_heading">
            <h2>{{ section.settings.main_heading }}</h2>
          </div>
        {% endif %}
        <div class="tiktok_sub_heading">
          <h3>{{ section.settings.sub_heading }}</h3>
        </div>
      </div>

      <div class="tiktok_slider">
        <div class="tiktok_slider_inner">
          {% for block in section.blocks %}
            <div class="tiktok_slider_row" {{ block.shopify_attributes }}>
              <div class="tiktok_slider_video" data-video-url="{{ block.settings.url_video | escape }}">
                {%- if block.settings.video_poster != blank -%}
                  <img
                    class="tiktok_video_poster"
                    src="{{ block.settings.video_poster | image_url: width: 506 }}"
                    srcset="{{ block.settings.video_poster | image_url: width: 506 }} 1x, {{ block.settings.video_poster | image_url: width: 1012 }} 2x"
                    alt="{{ block.settings.url_video_text | escape }}"
                    width="506"
                    height="450"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    decoding="async"
                  >
                {%- endif -%}
                <video
                  class="cm_video"
                  playsinline="" loop=""
                    {% if forloop.index == 1 %}
                      autoplay=""
                      muted=""
                    {% endif %}
                  width="100%"
                  height="100%"
                >
                  {%- comment -%} src injected by JS only for active/nearby slides {%- endcomment -%}
                  <source data-src="{{ block.settings.url_video }}" type="video/mp4">
                </video>
                {%- if block.settings.url_video_text != blank -%}
                  <h3 class="url_video_text">{{ block.settings.url_video_text }}</h3>
                {%- endif -%}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Tik Tok",
    "settings": [
      {
        "type" :"text",
        "id" : "main_heading",
        "label" : "Main Heading",
        "default": "we're going"
      },
      {
        "type" : "text",
        "id" : "sub_heading",
        "label" : "Sub Heading",
        "default": "viral"
      },
      {
        "type" : "html",
        "id" : "top_icon",
        "label" : "Tik Tok Icon"
      },
      {
        "type" : "text",
        "id" : "top_heading",
        "label" : "Top Text"
      }
    ],

    "blocks":[
      {
        "type":"text",
        "name":"Video Slider",
        "settings":[
          {
            "type":"text",
            "id":"url_video",
            "label":"Video URL (MP4)"
          },
          {
            "type":"image_picker",
            "id":"video_poster",
            "label":"Video poster image",
            "info":"Preview before video loads. Recommended 506×450 px (JPG/WebP). Without this, the slide shows empty until the MP4 downloads."
          },
          {
            "type":"textarea",
            "id":"url_video_text",
            "label":"Text"
          },
          {
            "type":"url",
            "id":"url",
            "label":"URL"
          }
        ]
      }
    ],

    "presets":[
      {
        "name":"Tik Tok"
      }
    ]
  }
{% endschema %}

<script>
  $(document).ready(function () {
    var $slider = $('.tiktok_slider_inner');
    if (!$slider.length || typeof $.fn.slick !== 'function') return;

    function loadTiktokVideo($video) {
      var $source = $video.find('source');
      var src = $source.attr('data-src');
      if (!src || $source.attr('src')) return;
      $source.attr('src', src);
      $video[0].load();
    }

    function unloadTiktokVideo($video) {
      var el = $video[0];
      if (!el) return;
      el.pause();
      el.removeAttribute('src');
      $video.find('source').removeAttr('src');
      el.load();
      $video.closest('.tiktok_slider_video').removeClass('is-playing is-loading');
    }

    function playTiktokSlide($slide) {
      var $wrap = $slide.find('.tiktok_slider_video');
      var $video = $wrap.find('video');
      if (!$video.length) return;

      $wrap.addClass('is-loading');
      loadTiktokVideo($video);

      var el = $video[0];
      var onPlaying = function () {
        $wrap.removeClass('is-loading').addClass('is-playing');
        el.removeEventListener('playing', onPlaying);
      };
      el.addEventListener('playing', onPlaying);

      el.play().catch(function () {
        $wrap.removeClass('is-loading');
      });
    }

    function pauseAllTiktokVideos($exceptSlide) {
      $slider.find('.slick-slide').each(function () {
        if ($exceptSlide && this === $exceptSlide[0]) return;
        unloadTiktokVideo($(this).find('video'));
      });
    }

    function handleActiveSlide(slick, slideIndex) {
      var $slide = $(slick.$slides.get(slideIndex));
      pauseAllTiktokVideos($slide);
      playTiktokSlide($slide);
    }

    $slider.on('init', function (event, slick) {
      handleActiveSlide(slick, slick.currentSlide);
    });

    $slider.on('beforeChange', function (event, slick) {
      pauseAllTiktokVideos();
    });

    $slider.on('afterChange', function (event, slick, currentSlide) {
      handleActiveSlide(slick, currentSlide);
    });

    $slider.slick({
      centerMode: true,
      slidesToShow: 5,
      slidesToScroll: 1,
      infinite: true,
      centerPadding: '0px',
      speed: 500,
      variableWidth: true,
      arrows: true,
      dots: false
    });
  });



