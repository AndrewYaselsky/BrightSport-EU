<script>
  document.addEventListener('DOMContentLoaded', () => {
    const wrapper = document.getElementById('sliderWrapper');
    const slides = wrapper.children;
    const totalSlides = slides.length;
    const paginationContainer = document.getElementById('pagination');
  
    let currentIndex = 0;
    let intervalTime = 5000;
    let slideInterval;
  
    for (let i = 0; i < totalSlides; i++) {
      const dot = document.createElement('button');
      dot.addEventListener('click', () => moveToSlide(i));
      paginationContainer.appendChild(dot);
    }
  
    const paginationDots = paginationContainer.children;
    paginationDots[0].classList.add('active');
  
    function moveToSlide(index) {
      currentIndex = index;
      wrapper.style.transform = `translateX(-${currentIndex * 100}%)`;
      updatePagination();
    }
  
    function updatePagination() {
      Array.from(paginationDots).forEach(dot => dot.classList.remove('active'));
      paginationDots[currentIndex].classList.add('active');
    }
  
    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalSlides;
      moveToSlide(currentIndex);
    }
  
    function startSlider() {
      slideInterval = setInterval(nextSlide, intervalTime);
    }
  
    function stopSlider() {
      clearInterval(slideInterval);
    }
  
    startSlider();
  
    wrapper.addEventListener('mouseenter', stopSlider);
    wrapper.addEventListener('mouseleave', startSlider);
  });
</script>

<script>
  function triggerMainButtonClick() {
    const mainButton = document.querySelector(".ProductForm__AddToCart");
    if (mainButton) {
      mainButton.click();
    } else {
      console.warn("Main button not found!");
    }
  }
  
  document.querySelector(".button-v2").addEventListener("click", triggerMainButtonClick);

  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
  
      const targetId = this.getAttribute('href').substring(1);
      const targetElement = document.getElementById(targetId);
  
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

