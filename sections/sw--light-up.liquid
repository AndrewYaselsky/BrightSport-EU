<div class="light_up">
  {% if section.settings.img != blank %}
    <img src="{{ section.settings.img | img_url: 'master' }}" class="light_up_bg">
  {% endif %}
  
  <div class="container">
  
    <div class="light_up_main">
      {% if section.settings.title != blank %}
        <h2 class="light_up_title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.caption != blank %}
        <p class="light_up_caption">{{ section.settings.caption }}</p>
      {% endif %}
      {% if section.settings.btn != blank %}
        <a href="{{ section.settings.url }}" class="new_common_btn">{{ section.settings.btn }}
          <span class="new_common_btn_icon">
            <svg width="20" height="14" viewBox="0 0 20 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M13.6882 0.29099C13.3019 -0.0969967 12.7222 -0.0969967 12.3358 0.29099C11.9493 0.678988 11.9493 1.26097 12.3358 1.64895L16.7153 5.9815H0.966082C0.450835 6.04613 0 6.4988 0 7.01622C0 7.53352 0.450835 7.98618 0.966082 7.98618H16.7153L12.3358 12.3833C11.9493 12.7714 11.9493 13.3533 12.3358 13.7413C12.5289 13.9354 12.7866 14 13.0442 14C13.3019 14 13.5594 13.9354 13.7527 13.7413L19.7424 7.72753C19.9356 7.53352 20 7.27487 20 7.01622C20 6.75745 19.8712 6.4988 19.7424 6.3049L13.6882 0.29099Z" fill="currentColor"/>
            </svg>
          </span>
        </a>
      {% endif %}

        <div class="light_up_list">
          {{ section.settings.payment_icon }}
    </div>
                
    </div>
  
  </div>
  
  <div class="bundle_scrollbar_col light_up_scrollbar">
    <div class="bundle_scrollbar_box">
      <div class="bundle_scrollbar_text">
        {% for i in (1..5) %}
          <p>{{ settings.annotext }}</p>
        {% endfor %}
      </div>    
    </div>
  </div>
</div>

<style>
  .light_up_list svg g {
    fill: #000;
  }
</style>
          

{% schema %}
{
  "name": "Light Up",
  "class": "sw--light-up",
  "settings": [
    {
      "type": "image_picker",
      "id": "img",
      "label": "Select Image"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "btn",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    },
    {
      "type": "html",
      "id": "payment_icon",
      "label" : "Payment Icon"
    }
  ],
  "blocks":[
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets":[
    {
      "name": "Light Up"
    }
  ]
}
{% endschema %}
