              {%- endfor -%}
            {%- endcapture -%}
    {% comment %}
            {%- if payment_methods != blank -%}
              <ul class="footer_payment_icon_list">
                {{ payment_methods }}
              </ul>
            {%- endif -%}
            {% endcomment %}

              <div class="footer_payments">
                {{ section.settings.footer_payment_icon }}
              </div>
            
          </div>
        </div>
      </div>

      <div class="footer_newsletter_block">
        <div class="footer_newsletter_wrapper">
          <h2 class="footer_title">{{ section.settings.news_title }}</h2>
          <p class="footer_newsletter_cap">{{ section.settings.cap }}</p>
          {%- form 'customer', id: 'footer-newsletter', class: 'Footer__Newsletter Form' -%}
