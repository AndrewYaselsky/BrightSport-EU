            <div class="weg_container">
              {% include 'region-selector-footer' %}
{% assign current_lang = localization.language.iso_code | downcase %}

<div class="weglot-container" id="weglot-switcher-2" data-switcher-id="2">
  <aside
    class="weglot_switcher country-selector default closed wg-drop"
    data-wg-notranslate="true"
    aria-label="Geselecteerde taal: {% case current_lang %}{% when 'nl' %}Nederlands{% when 'pt' %}Português{% when 'fi' %}Suomi{% when 'sv' %}Svenska{% when 'no' %}Norsk{% when 'da' %}Dansk{% when 'en' %}English{% when 'de' %}Deutsch{% when 'fr' %}Français{% when 'it' %}Italiano{% when 'es' %}Español{% else %}{{ current_lang | upcase }}{% endcase %}"
  >
    <div
      class="wg-li {{ current_lang }} wgcurrent wg-flags"
      data-l="{{ current_lang }}"
      role="combobox"
      aria-label="Taalwisselaar"
      aria-expanded="false"
      aria-controls="weglot-listbox"
    >
      <a href="{% if current_lang == 'nl' %}/{% else %}/{{ current_lang }}{% endif %}" id="weglot-language-{{ current_lang }}" lang="{{ current_lang }}">
        <img
          src="https://cdn.weglot.com/flags/circle/{% case current_lang %}{% when 'en' %}gb{% when 'da' %}dk{% when 'sv' %}se{% else %}{{ current_lang }}{% endcase %}.svg"
          width="24"
          height="24"
          alt=""
          class="wg-flag"
        >
        {% case current_lang %}
          {% when 'nl' %}Nederlands
          {% when 'pt' %}Português
          {% when 'fi' %}Suomi
          {% when 'sv' %}Svenska
          {% when 'no' %}Norsk
          {% when 'da' %}Dansk
          {% when 'en' %}English
          {% when 'de' %}Deutsch
          {% when 'fr' %}Français
          {% when 'it' %}Italiano
          {% when 'es' %}Español
          {% else %}{{ current_lang | upcase }}
        {% endcase %}
      </a>
    </div>

    <ul role="listbox" id="weglot-listbox" aria-label="Taallijst" style="display: none;">
      <li class="wg-li pt wg-flags" data-l="pt" role="option" id="wg-pt">
        <a href="/pt" id="weglot-language-pt" lang="pt">
          <img src="https://cdn.weglot.com/flags/circle/pt.svg" width="24" height="24" alt="" class="wg-flag">
          Português
        </a>
      </li>

      <li class="wg-li fi wg-flags" data-l="fi" role="option" id="wg-fi">
        <a href="/fi" id="weglot-language-fi" lang="fi">
          <img src="https://cdn.weglot.com/flags/circle/fi.svg" width="24" height="24" alt="" class="wg-flag">
          Suomi
        </a>
      </li>

      <li class="wg-li sv wg-flags" data-l="sv" role="option" id="wg-sv">
        <a href="/sv" id="weglot-language-sv" lang="sv">
          <img src="https://cdn.weglot.com/flags/circle/se.svg" width="24" height="24" alt="" class="wg-flag">
          Svenska
        </a>
      </li>

      <li class="wg-li no wg-flags" data-l="no" role="option" id="wg-no">
        <a href="/no" id="weglot-language-no" lang="no">
          <img src="https://cdn.weglot.com/flags/circle/no.svg" width="24" height="24" alt="" class="wg-flag">
          Norsk
        </a>
      </li>

      <li class="wg-li da wg-flags" data-l="da" role="option" id="wg-da">
        <a href="/da" id="weglot-language-da" lang="da">
          <img src="https://cdn.weglot.com/flags/circle/dk.svg" width="24" height="24" alt="" class="wg-flag">
          Dansk
        </a>
      </li>

      <li class="wg-li en wg-flags" data-l="en" role="option" id="wg-en">
        <a href="/en" id="weglot-language-en" lang="en">
          <img src="https://cdn.weglot.com/flags/circle/gb.svg" width="24" height="24" alt="" class="wg-flag">
          English
        </a>
      </li>

      <li class="wg-li de wg-flags" data-l="de" role="option" id="wg-de">
        <a href="/de" id="weglot-language-de" lang="de">
          <img src="https://cdn.weglot.com/flags/circle/de.svg" width="24" height="24" alt="" class="wg-flag">
          Deutsch
        </a>
      </li>

      <li class="wg-li fr wg-flags" data-l="fr" role="option" id="wg-fr">
        <a href="/fr" id="weglot-language-fr" lang="fr">
          <img src="https://cdn.weglot.com/flags/circle/fr.svg" width="24" height="24" alt="" class="wg-flag">
          Français
        </a>
      </li>

      <li class="wg-li it wg-flags" data-l="it" role="option" id="wg-it">
        <a href="/it" id="weglot-language-it" lang="it">
          <img src="https://cdn.weglot.com/flags/circle/it.svg" width="24" height="24" alt="" class="wg-flag">
          Italiano
        </a>
      </li>

      <li class="wg-li es wg-flags" data-l="es" role="option" id="wg-es">
        <a href="/es" id="weglot-language-es" lang="es">
          <img src="https://cdn.weglot.com/flags/circle/es.svg" width="24" height="24" alt="" class="wg-flag">
          Español
        </a>
      </li>
    </ul>
  </aside>
</div>
              <script>
                document.addEventListener('DOMContentLoaded', function () {
                  const switcher = document.querySelector('#weglot-switcher-2 .country-selector');
                  if (!switcher) return;

                  const trigger = switcher.querySelector('[role="combobox"]');
                  const listbox = switcher.querySelector('[role="listbox"]');

                  if (!trigger || !listbox) return;

                  function openDropdown() {
                    switcher.classList.remove('closed');
                    trigger.setAttribute('aria-expanded', 'true');
                    listbox.style.display = 'block';
                  }

                  function closeDropdown() {
                    switcher.classList.add('closed');
                    trigger.setAttribute('aria-expanded', 'false');
                    listbox.style.display = 'none';
                  }

                  function toggleDropdown(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const isOpen = trigger.getAttribute('aria-expanded') === 'true';
                    if (isOpen) {
                      closeDropdown();
                    } else {
                      openDropdown();
                    }
                  }

                  trigger.addEventListener('click', toggleDropdown);

                  trigger.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
                      e.preventDefault();
                      openDropdown();
                    }

                    if (e.key === 'Escape') {
                      closeDropdown();
                    }
                  });

                  document.addEventListener('click', function (e) {
                    if (!switcher.contains(e.target)) {
                      closeDropdown();
                    }
                  });
                });
              </script>
            </div>
          </div>
          <div class="footer_link_list">
             <h2 class="footer_title">{{ section.settings.title }}</h2>
            {%- assign linklist = linklists[section.settings.menu] -%}
            {%- if template.name == 'product' and product.tags contains 'bogo-deal' and section.settings.menu == 'bright' -%}
              {%- assign linklist = linklists['bright-bogo'] -%}
            {%- elsif template.name == 'collection' and collection.handle == 'bogo' and section.settings.menu == 'bright' -%}
              {%- assign linklist = linklists['bright-bogo'] -%}
            {%- endif -%}
              {%- if linklist != blank -%}
              <ul class="footer_link">
                {%- for link in linklist.links -%}
                  <li class="footer_link_item">
                    <a href="{{ link.url }}" class="Link Link--primary">{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {% endif %}
          </div>
          <div class="footer_link_list">
             <h2 class="footer_title">{{ section.settings.title1 }}</h2>
             {%- assign linklist = linklists[section.settings.menu1] -%}
              {%- if template.name == 'product' and product.tags contains 'bogo-deal' and section.settings.menu1 == 'bright' -%}
                {%- assign linklist = linklists['bright-bogo'] -%}
              {%- elsif template.name == 'collection' and collection.handle == 'bogo' and section.settings.menu1 == 'bright' -%}
                {%- assign linklist = linklists['bright-bogo'] -%}
              {%- endif -%}
              {%- if linklist != blank -%}
              <ul class="footer_link">
                {%- for link in linklist.links -%}
                  <li class="footer_link_item">
                    <a href="{{ link.url }}" class="Link Link--primary">{{ link.title | escape }}</a>
