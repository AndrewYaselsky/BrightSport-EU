<section class="bundle_common_scroll">
  <div class="bundle_function_wrapper">
    <div{% if template.name != 'index' %} class="container"{% endif %}>
      {% if section.settings.main_heading != blank %}
        <div class="bundle_function_heading " id="bundle">
          <h2>{{ section.settings.main_heading }}</h2>
        </div>
      {% endif %}
      {% if section.settings.sub_heading != blank %}
        <div class="bundle_function_sub_heading">
          <p>{{ section.settings.sub_heading }}</p>
        </div>
      {% endif %}
      <div class="bundle_function_block{% if template.name == 'index' %}  homepage-bundle-slider{% endif %}">
        <div class="bundle_function_col{% if template.name == 'index' %}  homepage-bundle-slide{% endif %}">
          <div class="bundle_function_sec">
            <div class="bundle_function_main_box">
              <div class="bundle_function_main_box_in">
                <div>
                  {% assign product = section.settings.product %}
                  {% if product.featured_image != blank %}
                    <div class="bundle_main_image">
                      <a href="{{ product.url }}">
                        <img src="{{ product.featured_image | img_url:'master' }}">
                      </a>
