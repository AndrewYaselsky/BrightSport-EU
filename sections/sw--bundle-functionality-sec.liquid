<script>
  $(document).ready(function() {

     $(".btns_cart").click(function(){
           $(".bundle_function_box .add_to_cart").removeClass("active");
           $(this).parents(".bundle_function_col").find(".bundle_function_box").each(function(){
             $(this).find(".add_to_cart").addClass("active");
           });

     var variantIDs = [];

         $(".bundle_function_box .add_to_cart.active").each(function(){
             variantIDs.push($(this).find('input[name="id"]').val());
         });

         $.ajax({
             url: '/cart/add.js',
             type: 'POST',
             dataType: 'json',
             data: { quantity: 1, id: variantIDs },
             success: function(response) {
                 window.location.href = '/cart';
             },
             error: function(jqXHR, textStatus, errorThrown) {
             }
             });
         });


     });
</script>

