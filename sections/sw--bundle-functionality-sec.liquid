                          </span>
                          Bundle
                        </div>
                      </div>
                    </div>
                  {% endif %}
                  <div class="bundle_main_title">
                    <h3>
                      <a href="{{ product.url }}">
                        {% assign title_words = product.title | split: ' ' %}
                        {% if title_words.size >= 2 %}
                          <span class="product_sub_title"> {{ title_words[0] }} </span>
                          <span class="product_main_title">
                            {{- title_words[1] }}
                            {{ title_words[2] }}
                            {{ title_words[3] }}
                            {{ title_words[4] }}
                            {{ title_words[5] }}
                            {{ title_words[6] -}}
                          </span>
                        {% else %}
                          <span class="product_main_title"> {{ product.title }}</span>
                        {% endif %}
                      </a>
                    </h3>
                  </div>
                  <div class="bundle_function_bottom_col">
                    <div class="bundle_left_col">
                      <div class="bundle_reivews">
                        <div
                          class="loox-rating"
                          data-id="{{ product.id }}"
                          data-rating="{{ product.metafields.loox.avg_rating }}"
                          data-raters="{{ product.metafields.loox.num_reviews }}"
                          style="text-align:center"
                        ></div>
                      </div>
                      <div class="price">
                        <div class="discount_price_col">
                          <div class="bundle_discount_price_wrap">
                            <span class="total_value"
                              >Total Value <span class="product_price">{{ product.compare_at_price | money_without_trailing_zeros }}</span></span
                            >
                            <div class="percentage_price_col">
                              <span>{{ product.price | money_without_trailing_zeros }}</span>
  
                              {% assign old_price = product.selected_or_first_available_variant.compare_at_price %}
                              {% assign new_price = product.selected_or_first_available_variant.price %}
                              
                              {% assign discount_amount = new_price | times: 100 %}
                              {% assign get_diff = discount_amount | divided_by: old_price %}
                              
                              {% assign discount_percentage = 100 | minus: get_diff | round: 0 %}
                              
                              {% if discount_percentage >= 40 and discount_percentage < 45 %}
                                {% assign display_discount = 40 %}
                              {% elsif discount_percentage >= 45 and discount_percentage < 49 %}
                                {% assign display_discount = 45 %}
                              {% elsif discount_percentage >= 49 %}
                                {% assign display_discount = 50 %}
                              {% else %}
                                {% assign display_discount = discount_percentage %}
                              {% endif %}
                              <div class="save_bg_color">Save {{ display_discount }}%</div>
                            </div>
                          </div>
                        </div>
                      </div>
    
                      {{ product.description }}
                    </div>
                  </div>
                </div>
                <div>
                  <div class="our_ball_product_add_to_cart">
                    <a href="{{ product.url | within: collection }}">
                      <button type="button" class="product_cart_add_btn ad_to_cart_coll">
                        Add Bundles
                      </button>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
