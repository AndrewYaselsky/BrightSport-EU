<section>
  <div class="bundle_marquee_wrapper">
    <div class="bundle_marquee_col">
      {% for block in section.blocks %}
        <div class="bundle_marquee_box">
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bundle Marquee",
  "settings": [],
  "blocks" : [
    {
      "type" : "Marquee",
      "name" : "Marquee",
      "settings" : [
          {
            "type" : "textarea",
            "id" : "text",
            "label" : "Text"
          }
      ]
    }
  ],
  "presets" : [
    {
       "name" : "Bundle Marquee"
    }
  ]
}
{% endschema %}
