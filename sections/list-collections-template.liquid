{%- if template == 'list-collections' -%}
  {%- assign linklist = linklists.all-collections -%}
{%- elsif template == 'page.collections' -%}
  {%- assign linklist_handle = page.content | strip_html | handle -%}
  {%- assign linklist = linklists[linklist_handle] -%}
{%- endif -%}

{%- assign collection_count = 0 -%}

{%- unless linklist.empty? -%}
  {%- for link in linklist.links -%}
    {%- if link.type == 'collection_link' -%}
      {%- assign collection_count = collection_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- for collection in collections -%}
    {%- unless collection.handle == 'frontpage' -%}
      {%- assign collection_count = collection_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endunless -%}

{%- if collection_count == 0 -%}
  <div class="EmptyState">
    <div class="container">
      <h3 class="EmptyState__Title Heading u-h5">{{ 'collection_list.general.empty_title' | t }}</h3>
      <a href="/" class="EmptyState__Action Button Button--primary">{{ 'collection_list.general.empty_button' | t }}</a>
    </div>
  </div>
{%- else -%}
  <section id="section-{{ section.id }}" data-section-id="{{ section.id }}" data-section-type="collection-list">
    <header class="PageHeader">
      <div class="SectionHeader SectionHeader--center">
        <h1 class="SectionHeader__Heading Heading u-h1">
          {%- if template == 'list-collections' -%}
            {{- 'collection_list.general.title' | t -}}
          {%- else -%}
            {{- page.title -}}
          {%- endif -%}
        </h1>
      </div>
    </header>

    <div class="CollectionList CollectionList--grid {% if section.settings.add_spacing %}CollectionList--spaced{% endif %}">
      
    <div class="CollectionItem" data-slide-index="0">
      <div class="CollectionItem__Wrapper CollectionItem__Wrapper--normal" style="background-image: url(https://cdn.shopify.com/s/files/1/0283/8190/4984/files/ball.jpg?v=1697733417)">
        <div class="CollectionItem__ImageWrapper">
          <div class="CollectionItem__Image Image--contrast Image--zoomOut hide-no-js Image--lazyLoaded" style="background-image: url(&quot;https://cdn.shopify.com/s/files/1/0283/8190/4984/files/ball.jpg?v=1697733417&quot;);" data-optimumx="1.4" data-expand="-150"></div>
          <noscript>
            <div class="CollectionItem__Image Image--contrast" style="background-position: ; background-image: url(https://cdn.shopify.com/s/files/1/0283/8190/4984/files/ball.jpg?v=1697733417)"></div>
          </noscript>
        </div>
    
        <div class="CollectionItem__Content CollectionItem__Content--bottomLeft">
          <header class="SectionHeader">
            <h2 class="SectionHeader__Heading SectionHeader__Heading--emphasize Heading u-h1">BALLS</h2>
            <div class="SectionHeader__ButtonWrapper"><a href="/collections/all#our-balls" class="CollectionItem__Link Button">View products</a></div>
          </header>
        </div>
      </div>
    </div>
    
    <div class="CollectionItem" data-slide-index="0">
      <div class="CollectionItem__Wrapper CollectionItem__Wrapper--normal" style="background-image: url(https://cdn.shopify.com/s/files/1/0283/8190/4984/files/Group5.png?v=1696427265)">
        <div class="CollectionItem__ImageWrapper">
          <div class="CollectionItem__Image Image--contrast Image--zoomOut hide-no-js Image--lazyLoaded" style="background-image: url(&quot;https://cdn.shopify.com/s/files/1/0283/8190/4984/files/Group5.png?v=1696427265&quot;);" data-optimumx="1.4" data-expand="-150"></div>
          <noscript>
            <div class="CollectionItem__Image Image--contrast" style="background-position: ; background-image: url(https://cdn.shopify.com/s/files/1/0283/8190/4984/files/Group5.png?v=1696427265)"></div>
          </noscript>
        </div>
    
        <div class="CollectionItem__Content CollectionItem__Content--bottomLeft">
          <header class="SectionHeader">
            <h2 class="SectionHeader__Heading SectionHeader__Heading--emphasize Heading u-h1">BUNDLES</h2>
            <div class="SectionHeader__ButtonWrapper"><a href="/collections/all#bundle" class="CollectionItem__Link Button">View products</a></div>
          </header>
        </div>
      </div>
    </div>
    
    <div class="CollectionItem" data-slide-index="0">
      <div class="CollectionItem__Wrapper CollectionItem__Wrapper--normal" style="background-image: url(//cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_1x1.png?v=1697734230)">
        <div class="CollectionItem__ImageWrapper">
          <div class="CollectionItem__Image Image--contrast Image--zoomOut hide-no-js Image--lazyLoaded" style="background-image: url(&quot;https://cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_750x848.png?v=1697734230&quot;);" data-optimumx="1.4" data-expand="-150" data-bgset="//cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_750x848.png?v=1697734230 750w, //cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_1000x.png?v=1697734230 1000w, //cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_1500x.png?v=1697734230 1500w">
          </div>
          <noscript>
            <div class="CollectionItem__Image Image--contrast" style="background-position: ; background-image: url(//cdn.shopify.com/s/files/1/0283/8190/4984/files/image_2023-10-19_195021950_1000x.png?v=1697734230)"></div>
          </noscript>
        </div>
    
        <div class="CollectionItem__Content CollectionItem__Content--bottomLeft">
          <header class="SectionHeader">
            <h2 class="SectionHeader__Heading SectionHeader__Heading--emphasize Heading u-h1">ACCESSORIES</h2>
            <div class="SectionHeader__ButtonWrapper"><a href="/collections/all#accessories" class="CollectionItem__Link Button">View products</a></div>
          </header>
        </div>
      </div>
    </div>
  
    </div>
  </section>
{%- endif -%}

<style>
  #section-{{ section.id }} .CollectionItem .Heading {
    color: {{ section.settings.text_color }};
  }

  #section-{{ section.id }} .CollectionItem__Link {
    color: {{ section.settings.button_color }};
    border-color: {{ section.settings.text_color }};
  }

  #section-{{ section.id }} .CollectionItem__Link::before {
    background-color: {{ section.settings.text_color }};
  }

  @media (-moz-touch-enabled: 0), (hover: hover) {
    #section-{{ section.id }} .CollectionItem__Link:hover {
      color: {{ section.settings.text_color }};
    }
  }
</style>

{% schema %}
{
  "name": "List collections page",
  "settings": [
    {
      "type": "select",
      "id": "image_size",
      "label": "Image size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "add_spacing",
      "label": "Add spacing",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "expand_collection",
      "label": "Expand collections to fill row",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "apply_overlay",
      "label": "Apply overlay on image",
      "info": "This can improve text visibility.",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text",
      "default": "#363636"
    }
  ]
}
{% endschema %}