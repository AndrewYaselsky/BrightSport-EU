      function updateGiftWrapStatus() {
        const GIFT_WRAP_VARIANT_ID = parseInt('{{ all_products["giftbagandcard"].selected_or_first_available_variant.id }}');
        const CHECKBOX_ID = 'ifAddAddon';
        const $checkbox = $('#' + CHECKBOX_ID);

        if (!GIFT_WRAP_VARIANT_ID || $checkbox.length === 0) {
          return;
        }

        jQuery.getJSON('/cart.js')
          .done(function(cart) {
            let isGiftWrapInCart = false;
            let giftWrapItem = null;

            cart.items.forEach(item => {
              if (item.variant_id === GIFT_WRAP_VARIANT_ID) {
                isGiftWrapInCart = true;
                giftWrapItem = item;
              }
            });

            if (isGiftWrapInCart) {
              $checkbox.prop('checked', true);
              const price = giftWrapItem.price / 100;
            } else {
              $checkbox.prop('checked', false);
            }
          })
          .fail(function (jqXHR) {
            console.error("⚠️ [Gift Wrap Status] Помилка завантаження кошика для перевірки статусу.", jqXHR.status);
          });
      }

      $(document).on('change', '#ifAddAddon', function () {
        var isChecked = $(this).is(':checked');
        var variantId = '{{ all_products["giftbagandcard"].selected_or_first_available_variant.id }}';
        var qty = isChecked ? 1 : 0;
        var rootUrl = (window.Shopify && Shopify.routes ? Shopify.routes.root : '/');

        var data = {};
        data['updates[' + variantId + ']'] = qty;
        
        $.ajax({
          type: 'POST',
          url: rootUrl + 'cart/update.js',
          data: data,
          dataType: 'json'
        })
        .done(function(cart) {
          if (typeof GLOBAL_RENDERCART !== 'undefined' && GLOBAL_RENDERCART._rerenderCart) {
            GLOBAL_RENDERCART._rerenderCart().then(function() {
              setTimeout(function() {
                updateGiftWrapStatus(); 
              }, 50);
            });
          } else {
            updateGiftWrapStatus();
          }
        })
        .fail(function (jqXHR) {
          console.error('Gift wrap toggle failed:', jqXHR.status, jqXHR.responseText);
        });
      });

      $(document).ready(function() {
        updateGiftWrapStatus();

        const $checkbox = $('#ifAddAddon');
        $checkbox.prop('checked', true).trigger('change');
      });

      $(document).on('click', '.rb-check-btn', function (e) {
        e.preventDefault();
        e.stopImmediatePropagation();

        const cartRedirectUrl = $('.Cart.Drawer__Content').attr('action');
        window.location.href = cartRedirectUrl;
      });
    </script>

