  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var checkInterval = setInterval(function() {
        var floatBlock = document.querySelector('.ht-tms--float');
    
        var langSelector = document.getElementById('langSelector');
        var langSelectorSlider = document.getElementById('langSelectorSlider');
    
        if (floatBlock) {
          if (window.innerWidth > 1024 && langSelector) { 
            langSelector.appendChild(floatBlock);
            clearInterval(checkInterval);
          } else if (window.innerWidth <= 1024 && langSelectorSlider) { 
            langSelectorSlider.appendChild(floatBlock);
            clearInterval(checkInterval);
          }
        }
      }, 200);
    });
  </script>

